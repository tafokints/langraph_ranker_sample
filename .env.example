# MySQL (required)
DB_HOST=your-mysql-host
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=your-database-name
DB_PORT=3306

# LLM (required for LLM-enabled LangGraph run)
OPENAI_API_KEY=sk-...
# Optional: override default model
# OPENAI_MODEL=gpt-4o-mini

# LangSmith tracing (optional; when enabled every graph run is a trace tree
# with each node as a child run, and the run URL is surfaced in the UI).
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=langgraph-recruiter-demo
# LANGCHAIN_TRACING_V2 is the legacy name; langsmith>=0.1.0 also honors it.
# LANGCHAIN_TRACING_V2=true
